# ============================================================
# ChannelView — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---- Core ----
SECRET_KEY=generate-a-strong-random-secret-here
FLASK_ENV=production            # development | staging | production
PORT=5000
HOST=0.0.0.0

# ---- Database ----
DB_PATH=channelview.db          # SQLite path (for PostgreSQL, see below)
# DATABASE_URL=postgresql://user:pass@host:5432/channelview

# ---- Email (SendGrid recommended) ----
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=ChannelView

# ---- Email (SMTP alternative) ----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password-here
# SMTP_FROM_EMAIL=you@gmail.com
# SMTP_FROM_NAME=ChannelView

# ---- Stripe (Billing) ----
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_PRICE_ID=price_your-monthly-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ---- Video Storage ----
STORAGE_BACKEND=local            # local | s3
# S3 (required if STORAGE_BACKEND=s3)
S3_BUCKET=channelview-videos
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_ENDPOINT=                     # Leave blank for AWS, or set for MinIO/R2
S3_PREFIX=videos/
S3_PRESIGN_EXPIRY=3600

# ---- AI Scoring (Claude) ----
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- File Upload Limits ----
MAX_UPLOAD_MB=500
MAX_RESPONSE_MB=100

# ---- CORS ----
CORS_ORIGINS=https://yourdomain.com
